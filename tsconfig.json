{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@moritzbrantner/graph-editor": ["./src/index.ts"],
      "@moritzbrantner/graph-editor/core": ["./src/core.ts"],
      "@moritzbrantner/graph-editor/layout": ["./src/layout.ts"],
      "@moritzbrantner/graph-editor/react": ["./src/react.tsx"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx"
  ]
}
