{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vite/client"],
    "paths": {
      "@moritzbrantner/graph-editor": ["./src/index.ts"],
      "@moritzbrantner/graph-editor/core": ["./src/core.ts"],
      "@moritzbrantner/graph-editor/layout": ["./src/layout.ts"],
      "@moritzbrantner/graph-editor/operations": ["./src/operations.ts"],
      "@moritzbrantner/graph-editor/runtime": ["./src/runtime.ts"],
      "@moritzbrantner/graph-editor/commands": ["./src/commands.ts"],
      "@moritzbrantner/graph-editor/serialization": ["./src/serialization.ts"],
      "@moritzbrantner/graph-editor/persistence": ["./src/persistence.ts"],
      "@moritzbrantner/graph-editor/patches": ["./src/patches.ts"],
      "@moritzbrantner/graph-editor/plugins": ["./src/plugins.ts"],
      "@moritzbrantner/graph-editor/interaction": ["./src/interaction.ts"],
      "@moritzbrantner/graph-editor/operation-log": ["./src/operation-log.ts"],
      "@moritzbrantner/graph-editor/react": ["./src/react.tsx"]
    }
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/.storybook/**/*.ts",
    "src/react.e2e-app/**/*.ts",
    "src/react.e2e-app/**/*.tsx",
    "examples/workbench/src/**/*.ts",
    "examples/workbench/src/**/*.tsx",
    "examples/workbench/src/**/*.d.ts"
  ],
  "exclude": []
}
