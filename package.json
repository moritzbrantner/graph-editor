{
  "name": "@moritzbrantner/graph-editor",
  "version": "0.1.0",
  "private": false,
  "homepage": "https://github.com/moritzbrantner/graph-editor#readme",
  "bugs": {
    "url": "https://github.com/moritzbrantner/graph-editor/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moritzbrantner/graph-editor.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./operations": {
      "types": "./dist/operations.d.ts",
      "import": "./dist/operations.js"
    },
    "./commands": {
      "types": "./dist/commands.d.ts",
      "import": "./dist/commands.js"
    },
    "./serialization": {
      "types": "./dist/serialization.d.ts",
      "import": "./dist/serialization.js"
    },
    "./persistence": {
      "types": "./dist/persistence.d.ts",
      "import": "./dist/persistence.js"
    },
    "./patches": {
      "types": "./dist/patches.d.ts",
      "import": "./dist/patches.js"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.js"
    },
    "./interaction": {
      "types": "./dist/interaction.d.ts",
      "import": "./dist/interaction.js"
    },
    "./operation-log": {
      "types": "./dist/operation-log.d.ts",
      "import": "./dist/operation-log.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup src/index.ts src/core.ts src/react.tsx src/layout.ts src/runtime.ts src/operations.ts src/commands.ts src/serialization.ts src/persistence.ts src/patches.ts src/plugins.ts src/interaction.ts src/operation-log.ts --format esm --dts --clean --out-dir dist",
    "build:examples": "vite build --config examples/workbench/vite.config.ts --outDir ../../dist-examples --emptyOutDir",
    "dev:examples": "vite --config examples/workbench/vite.config.ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --format=github",
    "prepack": "bun run build",
    "check-types": "tsc --noEmit",
    "check-types:tests": "tsc --noEmit -p tsconfig.test.json",
    "pack:check": "bun pm pack --dry-run",
    "smoke:package": "node scripts/smoke-package-exports.mjs",
    "test": "vitest run",
    "test:coverage": "node node_modules/vitest/vitest.mjs run --coverage",
    "test:e2e": "playwright test",
    "bench": "vitest bench --passWithNoTests --run",
    "check:editor-core": "node scripts/check-editor-core-consumption.mjs",
    "verify": "bun run format:check && bun run lint && bun run check:editor-core && bun run check-types && bun run check-types:tests && bun run test && bun run build && bun run smoke:package && bun run pack:check",
    "verify:full": "bun run verify && bun run test:coverage && bun run build:examples && bun run test:e2e"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@moritzbrantner/editor-core": "^0.2.1",
    "@moritzbrantner/ui": "^1.0.0",
    "lucide-react": "^1.17.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-istanbul": "4.1.8",
    "jsdom": "^26.1.0",
    "oxfmt": "0.52.0",
    "oxlint": "^1.61.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.0",
    "typescript": "6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "packageManager": "bun@1.3.14"
}
