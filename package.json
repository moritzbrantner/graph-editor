{
  "name": "@moritzbrantner/graph-editor",
  "version": "0.1.0",
  "private": false,
  "homepage": "https://github.com/moritzbrantner/graph-editor#readme",
  "bugs": {
    "url": "https://github.com/moritzbrantner/graph-editor/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moritzbrantner/graph-editor.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup src/index.ts src/core.ts src/react.tsx src/layout.ts --format esm --dts --clean --out-dir dist",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --format=github",
    "prepack": "bun run build",
    "check-types": "tsc --noEmit",
    "check-types:tests": "tsc --noEmit -p tsconfig.test.json",
    "pack:check": "bun pm pack --dry-run",
    "smoke:package": "node scripts/smoke-package-exports.mjs",
    "test": "$(dirname $(command -v npm))/node node_modules/vitest/vitest.mjs run",
    "verify": "bun run format:check && bun run lint && bun run check-types && bun run test && bun run build && bun run smoke:package && bun run pack:check"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@moritzbrantner/ui": "^0.8.0",
    "lucide-react": "^1.17.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-v8": "4.1.7",
    "jsdom": "^26.1.0",
    "oxfmt": "0.52.0",
    "oxlint": "^1.61.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "10.4.1",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.0",
    "typescript": "6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "packageManager": "bun@1.3.14"
}
